%% ── ARTIGO DO ORIENTADOR ────────────────────────────────────
\newcommand{\artigoOrientador}{%
  \ifthenelse{\equal{\@ppgccOrientadorFem}{sim}}{Orientadora}{Orientador}%
}
\newcommand{\artigoCoorientador}{%
  \ifthenelse{\equal{\@ppgccCoorientadorFem}{sim}}{Coorientadora}{Coorientador}%
}

%% ── TEXTO DE APRESENTAÇÃO NA FOLHA DE ROSTO ─────────────────
\newcommand{\textoApresentacao}{%
  \ifthenelse{\equal{\@ppgccTipoTrabalho}{dissertacao}}{%
    Dissertação apresentada ao \@ppgccPrograma\ da
    \@ppgccIES\ em associação ampla com a \@ppgccIESDois,
    como requisito parcial para obtenção do título de
    Mestre em \@ppgccArea.%
  }{%
    \ifthenelse{\equal{\@ppgccTipoTrabalho}{tese}}{%
      Tese apresentada ao \@ppgccPrograma\ da
      \@ppgccIES\ em associação ampla com a \@ppgccIESDois,
      como requisito parcial para obtenção do título de
      Doutor em \@ppgccArea.%
    }{%
      Trabalho de conclusão de curso apresentado ao
      \@ppgccPrograma\ da \@ppgccIES, como requisito
      parcial para obtenção do título de Mestre em
      \@ppgccArea.%
    }%
  }%
}

%% ── CAPA ────────────────────────────────────────────────────
\renewcommand{\imprimircapa}{%
  \begin{capa}%
    \center
    % Logos
    \begin{minipage}{0.45\textwidth}
      \centering
      \includegraphics[height=2.2cm]{lib/UFERSA}
    \end{minipage}%
    \hfill%
    \begin{minipage}{0.45\textwidth}
      \centering
      \includegraphics[height=2.2cm]{lib/UERN}
    \end{minipage}
    \vspace{0.3cm}

    % Instituições
    {\normalsize\bfseries\MakeUppercase{\@ppgccIES}}\\
    {\normalsize\bfseries\MakeUppercase{\@ppgccIESDois}}\\[0.2cm]
    {\normalsize\MakeUppercase{\@ppgccPrograma}}

    \vfill

    % Autor
    {\normalsize\bfseries\MakeUppercase{\imprimirautor}}

    \vfill

    % Título
    {\normalsize\bfseries\MakeUppercase{\imprimirtitulo}}

    \vfill

    % Local e ano
    {\normalsize\@ppgccLocal}\\
    {\normalsize\@ppgccAno}
  \end{capa}%
}

%% ── FOLHA DE ROSTO ───────────────────────────────────────────
\makeatletter
\renewcommand{\folhaderostocontent}{%
  \begin{center}
    {\normalsize\bfseries\MakeUppercase{\imprimirautor}}

    \vspace*{\fill}\vspace*{\fill}

    {\normalsize\bfseries\MakeUppercase{\imprimirtitulo}}

    \vspace*{\fill}

    \abntex@ifnotempty{\@ppgccEhQualificacao}{%
      \ifthenelse{\equal{\@ppgccEhQualificacao}{sim}}{%
        \hspace{.45\textwidth}%
        \begin{minipage}{.5\textwidth}%
          \SingleSpacing%
          {\normalsize Texto de qualificação apresentado ao
          \@ppgccPrograma\ da \@ppgccIES,
          como requisito parcial à obtenção do título de
          \ifthenelse{\equal{\@ppgccTipoTrabalho}{tese}}{Doutor}{Mestre}%
          ~em \@ppgccArea.}%
          \vspace*{.3cm}%
          {\normalsize \artigoOrientador: \@ppgccOrientador,
          \@ppgccOrientadorIES.}%
          \abntex@ifnotempty{\@ppgccCoorientador}{%
            \vspace*{.3cm}%
            {\normalsize \artigoCoorientador: \@ppgccCoorientador,
            \@ppgccCoorientadorIES.}%
          }%
        \end{minipage}%
      }{%
        \hspace{.45\textwidth}%
        \begin{minipage}{.5\textwidth}%
          \SingleSpacing%
          {\normalsize \textoApresentacao}%
          \vspace*{.3cm}%
          {\normalsize \artigoOrientador: \@ppgccOrientador,
          \@ppgccOrientadorIES.}%
          \abntex@ifnotempty{\@ppgccCoorientador}{%
            \vspace*{.3cm}%
            {\normalsize \artigoCoorientador: \@ppgccCoorientador,
            \@ppgccCoorientadorIES.}%
          }%
        \end{minipage}%
      }%
    }

    \vspace*{\fill}

    {\normalsize\@ppgccLocal}\\
    {\normalsize\@ppgccAno}
  \end{center}%
}
\makeatother

%% ── FOLHA DE APROVAÇÃO ───────────────────────────────────────
\newcommand{\imprimirfolhadeaprovacao}{%
  \begin{folhadeaprovacao}
    \begin{center}
      {\normalsize\bfseries\MakeUppercase{\imprimirautor}}\\[0.5cm]
      {\normalsize\bfseries\MakeUppercase{\imprimirtitulo}}\\[0.5cm]
      \hspace{.45\textwidth}
      \begin{minipage}{.5\textwidth}
        \SingleSpacing
        {\normalsize \textoApresentacao}
      \end{minipage}%
      \\[0.5cm]
      {\normalsize Aprovada em: \@ppgccDataAprovacao}\\[0.8cm]
      {\normalsize\bfseries BANCA EXAMINADORA}\\[0.5cm]
    \end{center}
    \assinatura{\@ppgccOrientador\ (\artigoOrientador)\\{\normalsize\@ppgccOrientadorIES}}
    \assinatura{\@ppgccBancaDois\\{\normalsize\@ppgccBancaDoisIES}}
    \assinatura{\@ppgccBancaTres\\{\normalsize\@ppgccBancaTresIES}}
    \abntex@ifnotempty{\@ppgccBancaQuatro}{%
      \assinatura{\@ppgccBancaQuatro\\{\normalsize\@ppgccBancaQuatroIES}}%
    }%
  \end{folhadeaprovacao}%
}

%% ── AMBIENTE PARA FIGURAS (legenda acima, fonte abaixo) ──────
% Uso: \begin{figura}{Título}{fig:label}{Autor (ANO)}
%        \includegraphics[width=.8\textwidth]{arquivo}
%      \end{figura}
\newenvironment{figura}[3]{%
  \begin{figure}[htb]
    \caption{#1}
    \label{#2}
    \begin{center}
}{%
    \end{center}
    \legend{\small Fonte: #3}
  \end{figure}
}

%% ── AMBIENTE PARA TABELAS (legenda acima, fonte abaixo) ──────
% Uso: \begin{tabela}{Título}{tab:label}{Autor (ANO)}
%        <conteúdo tabular>
%      \end{tabela}
\newenvironment{tabela}[3]{%
  \begin{table}[htb]
    \caption{#1}
    \label{#2}
    \begin{center}
}{%
    \end{center}
    \legend{\small Fonte: #3}
  \end{table}
}

%% ── QUADROS (sem linhas internas horizontais) ────────────────
\newenvironment{quadro}[3]{%
  \begin{table}[htb]
    \caption{#1}
    \label{#2}
    \begin{center}
}{%
    \end{center}
    \legend{\small Fonte: #3}
  \end{table}
}

